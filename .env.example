# ─── GitHub OAuth (global — required for server startup) ───
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ─── Security ───
ENCRYPTION_KEY=your-64-char-hex-encryption-key
SESSION_SECRET=your-session-secret

# ─── EmailJS (global account — sends to user's GitHub email) ───
EMAILJS_SERVICE_ID=your-emailjs-service-id
EMAILJS_TEMPLATE_ID=your-emailjs-template-id
EMAILJS_PUBLIC_KEY=your-emailjs-public-key
EMAILJS_PRIVATE_KEY=your-emailjs-private-key

# ─── Trigger Configuration ───
WEBHOOK_MODE=true
WEBHOOK_PORT=3001
WEBHOOK_SECRET=your-webhook-secret

# ─── MySQL ───
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=super_agent

# ─── Dashboard ───
DASHBOARD_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────
# All user-specific configuration (GitHub token, AI provider,
# AI API keys, repo settings, etc.) is managed per-user via
# the dashboard config page and stored in the database
# (user_configs table). Email notifications are sent to the
# user's GitHub email automatically.
# ─────────────────────────────────────────────────────────────
