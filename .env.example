# ─── GitHub Configuration ───
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your-github-username
# Leave empty to scan ALL repos for this owner
GITHUB_REPO=your-repo-name
DEV_BRANCH=dev

# ─── AI Provider Configuration ───
# Choose provider: 'gemini', 'openai', 'claude', or 'groq'
AI_PROVIDER=gemini

# ─── Gemini Configuration (required if AI_PROVIDER=gemini) ───
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ─── OpenAI Configuration (required if AI_PROVIDER=openai) ───
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# ─── Claude Configuration (required if AI_PROVIDER=claude) ───
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Groq Configuration (FREE — https://console.groq.com/keys) ───
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ─── EmailJS Configuration ───
EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
EMAILJS_PRIVATE_KEY=YOUR_PRIVATE_KEY

# ─── Trigger Configuration ───
WEBHOOK_MODE=true
CRON_MODE=true
POLL_INTERVAL_MINUTES=5
WEBHOOK_PORT=3000
WEBHOOK_SECRET=your-webhook-secret

# ─── Agent Configuration ───
ISSUE_LABEL=ai-agent
MAX_CONCURRENT_AGENTS=3
