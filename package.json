{
  "name": "super-agent",
  "version": "1.0.0",
  "description": "AI-powered multi-agent system for automated GitHub issue resolution",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:dashboard": "cd dashboard && npm run build",
    "build:all": "npm run build && npm run build:dashboard",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:dashboard": "cd dashboard && npm run dev",
    "dev:all": "npm run build:all && npm run dev",
    "test": "jest --config jest.config.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@emailjs/nodejs": "^5.0.2",
    "@google/generative-ai": "^0.24.1",
    "@octokit/oauth-app": "^8.0.3",
    "@octokit/rest": "^21.1.1",
    "@octokit/webhooks": "^13.4.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "mysql2": "^3.18.2",
    "openai": "^6.25.0",
    "express-mysql-session": "^3.0.3",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/express-mysql-session": "^3.0.8",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
